# pen_res_list <- readRDS(sprintf("%s/%s/results.rds", p_outdir, imp_type))
# ----- EN: raw/filterred autonest & save -----
for (dattype in c("auto", "autofilt")) {
if (dattype == "auto") {
autodt <- meta[Eggsignal > 0 & !(ani %in% ignore_anis),
.(ani, Date, Eggsignal, Nestnumber, Layingtime, EggID, type, ot_min, pen)]
} else if (dattype == "autofilt") {
autodt <- meta[Eggsignal > 0 & !(ani %in% ignore_anis) & F_combined == FALSE,
.(ani, Date, Eggsignal, Nestnumber, Layingtime, EggID, type, ot_min, pen)]
}
check <- autodt[, .N, by = .(Date, ani)][N>1]
if (nrow(check) > 0 ) warning("More than one egg per day for an animal is detected!")
autodt <- merge(autodt, ani_info,
by = "ani",
all.x = TRUE)
# add Birth
check <- autodt[is.na(Birth), .N, by = .(ani, Breed, Pen, Leave, Genotype, AnimalID)]
if (nrow(check) > 0) {
message("Animals without Birth (not genotyped and leave early): \n")
print(check)
mb <- autodt[, .N, by = Birth][order(-N), Birth[1]]
message("set their Birth to ",mb," (majority Birth)")
autodt[is.na(Birth), Birth := mb]
ani_info[is.na(Birth), Birth := mb]
}
#
from_date <- as.Date(min(autodt$Date, na.rm = TRUE))
to_date <- as.Date(max(autodt$Date, na.rm = TRUE))
n1 <- nrow(autodt[Eggsignal == 1])
# add dates for animals without records (0 egg) but persist
const_cols <- setdiff(colnames(autodt), c("Date", "Eggsignal", "Nestnumber", "Layingtime", "EggID", "type", "ot_min"))
all_dates <- autodt[, .(Date = seq(from_date, pmin(Leave, to_date), by = "day")), by = const_cols]
autodt <- merge(all_dates, autodt, by = c("Date", const_cols), all = TRUE)
autodt[is.na(Eggsignal), Eggsignal := 0]
n2 <- nrow(autodt[Eggsignal == 1])
if (n1 != n2) warning("Check autodt!")
automat <- dcast(autodt[, .(AnimalID, Date = as.character(Date), Eggsignal)],
Date ~ AnimalID,
value.var = "Eggsignal",
fill = NA,
fun.aggregate = sum) # autonest unfiltered could have >1 records per day
# EN periods
autodt[, week := as.integer(round(difftime(Date, Birth, units  = "weeks")))]
# print weeks
from_w <- as.integer(min(autodt$week))
to_w <- as.integer(max(autodt$week))
print(sprintf("Period %s: from %s weeks to %s weeks",dattype,from_w,to_w))
autodt[, wgrp := floor((week - from_w) / EN_period_perweek) + 1]
print(sprintf("Period: from EN%s to EN%s",min(autodt$wgrp),max(autodt$wgrp)))
autodt[, min_wgrp := min(wgrp), by = AnimalID]
autodt[, max_wgrp := max(wgrp), by = AnimalID]
table(autodt$min_wgrp)
table(autodt$max_wgrp)
automm <- autodt[, .(sum = sum(Eggsignal, na.rm = TRUE)), by = .(AnimalID, wgrp)][order(AnimalID, wgrp)]
automm[, wgrp := factor(paste0("EN", wgrp),
levels = paste0("EN", sort(unique(wgrp))))]
ENall <- automm[, .(wgrp = "ENall", sum = sum(sum, na.rm = TRUE)), by = AnimalID]
automm_mat <- dcast(rbind(automm, ENall), AnimalID ~ wgrp,
value.var = "sum",
fill = NA)
automm_mat <- merge(ani_info, automm_mat, by = "AnimalID")
# save
out_dir <- sprintf("%s/%s", p_outdir, dattype)
if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)
write.table(automat, sprintf("%s/%s/EN_matrix.txt", p_outdir, dattype), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
write.table(autodt, sprintf("%s/%s/EN_dt.txt", p_outdir, dattype), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
write.table(automm_mat, sprintf("%s/%s/EN_%s.txt", p_outdir, dattype, dattype), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
# plot
if (dattype == "auto") {
autodt[, month := format(Date, "%Y-%m")]
gg1 <- ggplot(autodt[Eggsignal == 1],
aes(x = Layingtime, fill = Breed)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = col_breed) +
facet_grid(Breed ~ month) +
labs(title = "Laying time distribution by Breed and Month (raw autonest)",
x = "Laying time", y = "Density") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
gg2 <- ggplot(autodt[Eggsignal == 1],
aes(x = Layingtime, fill = Breed)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = col_breed) +
facet_grid(Breed ~ wgrp) +
labs(title = "Laying time distribution by Breed and EN period (raw autonest)",
x = "Laying time", y = "Density") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggplot2::ggsave(sprintf("%s/%s/Dist_Layingtime_M.png", p_outdir, dattype), gg1, height = 9, width = 15, limitsize = FALSE)
ggplot2::ggsave(sprintf("%s/%s/Dist_Layingtime_EN.png", p_outdir, dattype), gg2, height = 9, width = 15, limitsize = FALSE)
}
}
# ----- Print: EN summary -----
g <- c(1:max(resdt$max_wgrp))
floorpen <- paste0("0", index_floornest)
brds <- c("all", unique(resdt$Breed))
resdt[, eid := as.character(eid)]
for (brd in brds) {
if (brd == "all") {
subdt <- resdt[wgrp %in% g]
subautodt <- autodt[wgrp %in% g]
} else {
subdt <- resdt[wgrp %in% g & Breed == brd]
subautodt <- autodt[wgrp %in% g & Breed == brd]
}
tot <- (subdt[!is.na(imptype), sum(egg)])
trust <- (subdt[imptype == "trust", sum(egg)])
assign_tot <- (subdt[imptype == "imp", sum(egg)])
subdt[, nest := substr(eid,7,9)]
assign_floor <- (subdt[nest == floorpen, sum(egg)])
assign_nest <- (subdt[nest != floorpen & imptype == "imp", sum(egg)])
if (assign_nest + assign_floor != assign_tot) warning("Number of assigned eggs do not match!")
nsam <- length(unique(subdt$AnimalID))
totauto <- nrow(subautodt[Eggsignal == 1])
cat("During EN",g,":\nBreed",brd,": In total there were",nsam,"animals remained, \nwith",totauto,"Autonest egg records;",tot,"egg assignments,
including",trust,"(",trust/tot,") trusted eggs,
we assigned",assign_tot,"(",assign_tot/tot,") eggs,
within the assignments",assign_floor,"(",assign_floor/tot,") eggs were floor eggs
and",assign_nest,"(",assign_nest/tot,") nest eggs."
)
}
