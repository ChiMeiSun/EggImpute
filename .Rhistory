#' Get removed eggs from function "process_pen"
#'
#' @param res_list A list contains "pen_priors" and "pen_trusted" output by pen
#'
#' @return A data.table of results,`eid`(egg id), `ani`, `layingtime`(from autonest)
#' `type`(primary/secondary), `date`, `pen`, `fold`(if CV=TRUE)
#' @export
#'
get_rmegg <- function(res_list) {
data.table::rbindlist(lapply(res_list, function(pen) {
x <- pen$pen_rmegg
}))
}
rmegg=get_rmegg(pen_res_list)
rmegg
#' Get removed eggs from function "process_pen"
#'
#' @param res_list A list contains "pen_priors" and "pen_trusted" output by pen
#'
#' @return A data.table of results,`eid`(egg id), `ani`, `layingtime`(from autonest)
#' `type`(primary/secondary), `date`, `pen`, `fold`(if CV=TRUE)
#' @export
#'
get_rmegg <- function(res_list) {
data.table::rbindlist(lapply(res_list, function(pen) {
x <- pen$pen_rmegg
setnames(x, "date", "eiddate")
}))
}
rmegg=get_rmegg(pen_res_list)
x <- pen$pen_rmegg
#' Get removed eggs from function "process_pen"
#'
#' @param res_list A list contains "pen_priors" and "pen_trusted" output by pen
#'
#' @return A data.table of results,`eid`(egg id), `ani`, `layingtime`(from autonest)
#' `type`(primary/secondary), `date`, `pen`, `fold`(if CV=TRUE)
#' @export
#'
get_rmegg <- function(res_list) {
data.table::rbindlist(lapply(res_list, function(pen) {
x <- pen$pen_rmegg
setnames("date", "eiddate", x)
}))
}
rmegg=get_rmegg(pen_res_list)
#' Get removed eggs from function "process_pen"
#'
#' @param res_list A list contains "pen_priors" and "pen_trusted" output by pen
#'
#' @return A data.table of results,`eid`(egg id), `ani`, `layingtime`(from autonest)
#' `type`(primary/secondary), `date`, `pen`, `fold`(if CV=TRUE)
#' @export
#'
get_rmegg <- function(res_list) {
dat <- data.table::rbindlist(lapply(res_list, function(pen) {
x <- pen$pen_rmegg
}))
setnames("date", "eiddate", dat)
return(dat)
}
rmegg=get_rmegg(pen_res_list)
