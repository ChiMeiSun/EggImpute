meta <- readRDS(sprintf("%s/data/meta_ready.rds", p_outdir))
ani_impeggs <- fread(sprintf("%s/data/HMM.txt", p_outdir))
negg <- fread(sprintf("%s/data/negg.txt", p_outdir))
attr(negg$date_time, "tzone")     <- timezone
attr(negg$date_time_pre, "tzone") <- timezone
pen_res_list <- readRDS(sprintf("%s/%s/results.rds", p_outdir, imp_type))
# ----- Info: read, prepare -----
info <- fread(p_info, header = TRUE)
ani_info <- info[DataSource == xDataSource & Generation == xGeneration,
.(AnimalID, Generation, DataSource, Breed, Birth, Leave, Genotype, Pen, TierID, KM, KM_alt)]
ani_info[, ani := sub(TierID_rmffix, "", TierID)]
# check if TierID is the mark in the autonest
ani_info[!ani %in% unique(meta$ani), diff := TRUE]
# if TierID do not appear, check KM/KM_alt as well, otherwise ani = 0
ani_info[diff == TRUE, ani := mapply(function(p, a, b) {
has_a <- nrow(meta[pen == p & ani == a]) > 0
has_b <- nrow(meta[pen == p & ani == b]) > 0
if (has_a & !has_b) {
return(a)
} else if (!has_a & has_b) {
return(b)
} else {
return(0)
}
}, Pen, KM, KM_alt)]
if (nrow(ani_info[ani == 0]) > 0) {
cat("Animals that did not appear in autonest records throughout the period: \n")
print(ani_info[ani == 0])
}
for (p in sort(unique(meta$pen))) {
anis <- meta[pen == p, unique(ani)]
anis <- anis[!anis %in% ignore_anis]
if (any(!anis %in% ani_info$ani & !anis %in% ani_info$KM & !anis %in% ani_info$KM_alt)) {
message("ani in autonest not found in ani_info, check pen ", p)
}
}
# adjust ani_info
ani_info[ani == 0, ani := sub(TierID_rmffix, "", TierID)]
# check
check <- ani_info[meta[, .(ani, Date)], on = .(ani = ani), nomatch = NULL][
Date > Leave,
.SD[which.max(Date)],
by = ani]
if(nrow(check) > 0) {
warning("Discordance between 'Leave' and 'Date' appearing in the autonest!")
print(check)
}
table(ani_info$Breed)
table(ani_info$Pen)
restt <- get_trusted(pen_res_list)
check <- restt[, if(.N > 1) .SD, by = .(date, ani)]
if (nrow(check) > 0 ) {
warning("Check trusted dt, dups for date/ani pair are detected!")
print(check)
}
# print period
from_d <- as.character(min(restt$date))
to_d <- as.character(max(restt$date))
print(sprintf("Trusted results period: %s to %s", from_d, to_d))
#imp assign
respp <- get_prob(pen_res_list)
check <- respp[, if(.N > 1) .SD, by = .(eid, pen)]
if (nrow(check) > 0 ) {
warning("Check trusted dt, dups for date/ani pair are detected!")
print(check)
}
# ----- EN: dt -----
resdt <- get_ENdt(pen_res_list, type = imp_type)
resdt <- resdt[, datelay := NULL]
## example of dup dates for an ani
# tmp <- resdt[, .N, by = .(eiddate, ani)][N>1]
# ridx <- sample(1:nrow(tmp), 1)
# td <- tmp[ridx, eiddate]
# ta <- tmp[ridx, ani]
# resdt[eiddate == td & ani == ta]
# Merge with info
resdt <- merge(ani_info, resdt,
by = "ani",
all = TRUE)
check <-resdt[is.na(AnimalID)]
if (nrow(check) > 0 ) {
warning("Unmatched ani without AnimalID detected!")
print(check)
}
resdt[, pen := NULL]
resdt[, diff := NULL]
cat("animals that do not have any egg assignment: \n")
resdt[is.na(prior), .N, by = .(Breed)]
table(resdt[is.na(date),imptype], useNA = "ifany")
resdt[is.na(date), date := as.Date(eiddate, format = "%y%m%d")]
# modify dup dates
dup_keys <- resdt[, .N, by = .(AnimalID, date)][N > 1, .(AnimalID, date)]
resdt[dup_keys, on = .(AnimalID, date),
date := fifelse(imptype == "imp", date - 1L, date)
]
check <- resdt[, if(.N > 1) .SD, by = .(AnimalID, date)]
if (nrow(check) > 0) {
message("Check date in dt! \n")
print(check)
}
message("Num of dup dates corrected: ",
resdt[, .N, by = .(AnimalID, eiddate)][N > 1, .N])
# check Birth
check <- resdt[is.na(Birth), .N, by = .(ani, Breed, Pen, Leave, Genotype, AnimalID)]
if (nrow(check) > 0) {
message("Animals without Birth (not genotyped and leave early): \n")
print(check)
mb <- resdt[, .N, by = Birth][order(-N), Birth[1]]
message("set their Birth to ",mb," (majority Birth)")
resdt[is.na(Birth), Birth := mb]
ani_info[is.na(Birth), Birth := mb]
}
from_date <- as.Date(min(resdt$date, na.rm = TRUE))
to_date <- as.Date(max(resdt$date, na.rm = TRUE))
# rm animals left too early
resdt <- resdt[! (is.na(prior) & Leave < from_date) ]
# add dates for animals with max assignment date < Leave (till measurement date "to_date" if Leave > to_date)
const_cols <- setdiff(colnames(resdt), c("date", "eiddate", "prior", "eid", "laytime", "type", "imptype"))
all_dates <- resdt[, .(date = seq(from_date, pmin(Leave, to_date), by = "day")), by = const_cols]
resdt <- merge(all_dates, resdt, by = c(const_cols, "date"), all = TRUE)
resdt[is.na(prior), prior := 0]
resdt <- resdt[!is.na(date)] # rm NA rows for animals that do not have any egg assignment
# resdt[AnimalID=="RH1731"] # Leave > to_date
# resdt[AnimalID=="RH1825"] # Leave < to_date
# resdt[AnimalID=="RH2101"] # not in assign
# resdt[AnimalID=="RH2266"] # no assignment
#
resdt[, week := as.integer((difftime(date, Birth, units  = "weeks")))]
# print weeks
from_w <- as.integer(min(resdt$week))
to_w <- as.integer(max(resdt$week))
print(sprintf("Period: from %s weeks to %s weeks",from_w,to_w))
resdt[, wgrp := floor((week - from_w) / EN_period_perweek) + 1]
print(sprintf("Period: from EN%s to EN%s",min(resdt$wgrp),max(resdt$wgrp)))
resdt[, min_wgrp := min(wgrp), by = AnimalID]
resdt[, max_wgrp := max(wgrp), by = AnimalID]
resdt[, .N, by = min_wgrp]
resdt[, .N, by = max_wgrp][order(max_wgrp)]
check <- resdt[imptype == "trust", if(.N >1) .SD, by = .(AnimalID, date)]
if (nrow(check) > 0 ){
message("Trust records were repeated, please check!")
print(check)
}
check <- resdt[!is.na(eid), if(.N > 1) .SD, by = .(eid, Pen)]
if (nrow(check) > 0 ){
message("Egg ids were repeated, please check!")
print(check)
}
# ----- EN: periods -----
if (nrow(resdt[is.na(prior)]) > 0 ) warning("NA detected in prior column!")
maxgrp <- resdt[, .(max_wgrp = max(wgrp)), by = AnimalID]
resmm <- resdt[, .(sum = sum(prior)), by = .(AnimalID, wgrp)][
CJ(AnimalID = unique(resdt$AnimalID), wgrp = min(wgrp):max(wgrp)),
on = .(AnimalID, wgrp)
][
, wgrp := factor(paste0("EN", wgrp), levels = paste0("EN", min(resdt$wgrp) : max(resdt$wgrp)))
]
ENall <- resmm[, .(wgrp = "ENall", sum = sum(sum, na.rm = TRUE)), by = AnimalID]
resmm_mat <- dcast(rbind(resmm, ENall), AnimalID ~ wgrp,
value.var = "sum")
resmm_mat <- merge(ani_info, resmm_mat, by = "AnimalID")
# ----- EN: matrix -----
resmat <- data.table::dcast(resdt, date ~ ani,
value.var = "prior",
fill = 0,
fun.aggregate = sum)
# resmat[1:5,1:5]
# Get row and column indices where value > 1
matrix <- as.matrix(resmat[, -1])
over_ones <- which(matrix > 1, arr.ind = TRUE)
if (nrow(over_ones) > 0) {
# Get row names (eiddate) and column names (ani)
date <- resmat$date[over_ones[, 1]]
ani <- colnames(resmat)[-1][over_ones[, 2]]
values <- matrix[over_ones]
dups <- data.table(
date = date,
ani = ani,
value = values
)[order(-value)]
# restt[, eiddate := substr(eid,1,6)]
# an animal could have >1 eggs for a given eiddate, due to long time interval between manual counts
# but for such records, restt have time stamps from autonest thus no >1 eggs on a given date will be observed (filtered)
check <- merge(restt, dups,
by = c("date", "ani"))
if (nrow(check[, .N, by = .(date, ani)][N>1]) > 0 ) {
warning("Check trusted dt from get_trusted(), dups for date/ani pair are detected!")
}
}
# ----- EN: plot -----
dat <- resdt[prior == 1 & imptype=="trust"]
dat[, month := format(date, "%Y-%m")]
gg1 <- ggplot(dat,
aes(x = laytime, fill = Breed)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = col_breed) +
facet_grid(Breed ~ month) +
labs(title = "Laying time distribution by Breed and Month (EN_dt trust)",
x = "Laying time", y = "Density") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
gg2 <- ggplot(dat,
aes(x = laytime, fill = Breed)) +
geom_density(alpha = 0.5) +
scale_fill_manual(values = col_breed) +
facet_grid(Breed ~ wgrp) +
labs(title = "Laying time distribution by Breed and EN period (EN_dt trust)",
x = "Laying time", y = "Density") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# ----- save imputation outputs -----
saveRDS(meta, sprintf("%s/data/meta_ready.rds", p_outdir))
fwrite(ani_impeggs, sprintf("%s/data/HMM.txt", p_outdir), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
ggplot2::ggsave(sprintf("%s/data/HMM_3ani.png", p_outdir), plots_HMM, height = 3 * 10, width = 3 * 13, limitsize = FALSE)
out_dir <- sprintf("%s/%s", p_outdir, imp_type)
if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)
saveRDS(pen_res_list, sprintf("%s/%s/results.rds", p_outdir, imp_type))
ggplot2::ggsave(sprintf("%s/Dist_Layingtime_M.png", out_dir), gg1, height = 9, width = 15, limitsize = FALSE)
ggplot2::ggsave(sprintf("%s/Dist_Layingtime_EN.png", out_dir), gg2, height = 9, width = 15, limitsize = FALSE)
fwrite(resmat, sprintf("%s/%s/EN_matrix.txt", p_outdir, imp_type), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
note_file <- file.path(sprintf("%s/%s", p_outdir, imp_type), "README_EN_matrix.txt")
note_content <- "This matrix contains 0 and 1; 0 can be no egg or animal did not persist on the day"
writeLines(note_content, note_file)
setnames(resdt, "prior", "egg")
resdt[, eiddate := as.Date(eiddate, format = "%y%m%d")]
setnames(resdt, "eiddate", "collectdate")
resdt[, laytime := as.character(laytime)]
fwrite(resdt[, -c("ani", "Genotype","eid", "KM", "KM_alt")],
sprintf("%s/%s/EN_dt.txt", p_outdir, imp_type), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
fwrite(resmm_mat[, -c("ani", "Genotype", "KM", "KM_alt", "diff")],
sprintf("%s/%s/EN_%s.txt", p_outdir, imp_type, imp_type), quote = FALSE, row.names = FALSE, col.names = TRUE, sep = "\t")
#
# meta <- readRDS(sprintf("%s/data/meta_ready.rds", p_outdir))
# ani_impeggs <- fread(sprintf("%s/data/HMM.txt", p_outdir))
# negg <- fread(sprintf("%s/data/negg.txt", p_outdir))
