library(data.table)
library(ggplot2)
get_crit <- function(x,y){
return(pmax(x,y)/(x+y))
}
n_inds <- 100
n_sel <- 10
sd_x <- 0.1
sd_y <- 0.1
n_gen <- 20
sd_x <- 0.1
basepop <- data.table(x = rnorm(n_inds), y=rnorm(n_inds))
basepop
basepop[,crit := get_crit(x,y),by=.(x,y)]
ggplot(basepop,aes(x=x,y=y,colour = crit))+geom_point()
for(i in 1:n_gen){
setorder(basepop,-crit)
basepop_sel <- basepop[1:n_sel]
new_pop <- data.table(
P1 = sample(1:n_sel,n_inds,TRUE),
P2 = sample(1:n_sel,n_inds,TRUE)
)
new_pop[,x:=(basepop_sel$x[P1]+basepop_sel$x[P2])/2+rnorm(.N,sd = sd_x)]
new_pop[,y:=(basepop_sel$y[P1]+basepop_sel$y[P2])/2+rnorm(.N,sd = sd_y)]
new_pop[,crit:=get_crit(x,y)]
pl <- ggplot(basepop,aes(x=x,y=y))+
geom_point(color = "grey")+
geom_point(color = "red",data=basepop_sel)+
geom_point(aes(color = crit),data=new_pop)+
labs(title=i)
print(pl)
basepop <- rbindlist(list(basepop,new_pop),fill=TRUE)
}
basepop_sel
new_pop
